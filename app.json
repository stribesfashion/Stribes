{
  "expo": {
    "name": "STRIBES",
    "slug": "stribes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "stribes",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#09090B"
    },
    "ios": {
      "supportsTablet": false,
      "deploymentTarget": "15.1",
      "bundleIdentifier": "com.stribes.app",
      "infoPlist": {
        "NSCameraUsageDescription": "STRIBES needs camera access to capture your outfits.",
        "NSPhotoLibraryUsageDescription": "STRIBES needs photo library access to upload your looks."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#09090B"
      },
      "package": "com.stribes.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "STRIBES needs photo access to upload your looks."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
